{
  "name": "weedit",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "WeEdit — a desktop video editor for Twitch VODs (WeVideo-inspired UI, Tauri + ffmpeg).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fetch-binaries": "node scripts/fetch-ffmpeg.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run fetch-binaries && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.460.0",
    "react": "^19",
    "react-dom": "^19",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "typescript": "^5",
    "vite": "^6"
  }
}
