{
  "name": "weedit",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "description": "WeEdit — a desktop video editor for Twitch VODs (WeVideo-inspired UI, Tauri + ffmpeg).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "tsc -b && vite build --config vite.web.config.ts",
    "preview": "vite preview",
    "preview:web": "vite preview --config vite.web.config.ts",
    "fetch-binaries": "node scripts/fetch-ffmpeg.mjs",
    "clean-installers": "node scripts/clean-installers.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run fetch-binaries && npm run clean-installers && tauri build",
    "tauri:build:release": "npm run fetch-binaries && npm run clean-installers && tauri build --config src-tauri/tauri.release.conf.json",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^0.460.0",
    "react": "^19",
    "react-dom": "^19",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.31",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10",
    "postcss": "^8",
    "tailwindcss": "^3.4",
    "typescript": "^5",
    "vite": "^8",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
